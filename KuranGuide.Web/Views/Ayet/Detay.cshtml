@model KuranGuide.Web.Models.AyetDetailViewModel
@{
    ViewData["Title"] = "Ayet Detay";
}

@section Styles {
    <style>
        /* 1. Arkaplan: Diğer sayfalarla uyumlu */
        body {
            background: radial-gradient(circle at 15% 20%, rgba(212, 175, 55, 0.035) 0%, transparent 45%), radial-gradient(circle at 85% 80%, rgba(90, 125, 124, 0.045) 0%, transparent 50%), #F7F7F4;
        }

        /* 2. Ayet Kartı (Buzlu Cam) */
        .ayet-shell {
            background: rgba(255, 255, 255, 0.75); /* Daha şeffaf */
            backdrop-filter: blur(16px); /* Bulanık arka plan */
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 24px;
            padding: 2.5rem 2rem;
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.05);
            position: relative;
            overflow: hidden;
        }

        /* Dekoratif Arkaplan İkonu */
        .card-bg-icon {
            position: absolute;
            top: -30px;
            right: -30px;
            font-size: 12rem;
            color: rgba(90, 125, 124, 0.03); /* Çok silik yaprak */
            pointer-events: none;
            z-index: 0;
        }

        /* Tipografi */
        .arabic-text {
            font-family: var(--arabic-font), serif;
            font-size: clamp(2rem, 4vw, 3rem);
            text-align: center;
            line-height: 2.2;
            color: #2C3E50;
        }

        .meal-text {
            font-family: 'Lora', serif;
            font-size: 1.4rem;
            line-height: 1.8;
            color: #4B5563;
        }

        /* Navigasyon Butonları */
        .nav-btn {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            padding: 0.8rem 1.5rem;
            border-radius: 50px;
            font-size: 0.95rem;
            font-weight: 600;
            color: #6B7280;
            background: rgba(255, 255, 255, 0.5);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            transition: all 0.2s ease;
            box-shadow: 0 4px 15px -3px rgba(0,0,0,0.05);
        }

            .nav-btn:hover {
                background: #ffffff;
                color: #5A7D7C;
                transform: translateY(-2px);
                box-shadow: 0 8px 20px -3px rgba(90, 125, 124, 0.15);
            }

        /* Buton Hover Efektleri */
        .action-button {
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

            .action-button:active {
                transform: scale(0.95);
            }
    </style>
}

<main class="w-full max-w-3xl mx-auto px-6 py-14 flex flex-col items-center relative z-10">

    <a href="/Sure/Detay/@Model.Ayet.SureId"
       class="mb-10 text-[11px] font-bold tracking-[0.2em] text-yaprak uppercase bg-yaprak/10 px-4 py-1.5 rounded-full border border-yaprak/20 hover:bg-yaprak hover:text-white transition-colors">
        @Model.Ayet.SureAdi Sûresi, @Model.Ayet.AyetNo. Ayet
    </a>

    <div class="ayet-shell w-full mb-10">

        <i class="ph ph-book-open-text card-bg-icon"></i>

        <p class="arabic-text mb-8 relative z-10" dir="rtl">
            @Model.Ayet.ArapcaMetin
        </p>

        <div class="relative z-10 w-32 h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent mx-auto mb-8"></div>

        <p class="meal-text text-center italic relative z-10">
            "@Model.Ayet.Meal"
        </p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Ayet.Aciklama))
    {
        <div class="w-full bg-white/60 backdrop-blur-md p-6 rounded-2xl border border-white/50 shadow-sm mb-12">
            <h4 class="font-serif font-medium text-yaprak mb-3 flex items-center gap-2 text-lg">
                <i class="ph ph-info text-xl"></i>
                Kısa Tefsir
            </h4>
            <p class="text-gray-600 text-base leading-relaxed font-light">
                @Model.Ayet.Aciklama
            </p>
        </div>
    }

    <div class="flex items-center gap-4 bg-white/90 backdrop-blur shadow-[0_15px_35px_-10px_rgba(0,0,0,0.1)] px-8 py-3 rounded-full border border-gray-100">

        <button type="button"
                class="favori-toggle action-button w-12 h-12 rounded-full flex items-center justify-center transition-all bg-red-50 hover:bg-red-100 hover:shadow-md"
                data-type="ayet"
                data-refid="@Model.Ayet.Id"
                title="Favorilere Ekle">
            <i class="ph ph-heart text-2xl @(Model.IsFavorited ? "ph-fill text-red-600" : "text-red-300")"></i>
        </button>

        <div class="w-px h-6 bg-gray-200"></div>

        <button onclick="downloadAyet()" class="action-button group w-12 h-12 rounded-full bg-yaprak/10 text-yaprak flex items-center justify-center hover:bg-yaprak hover:text-white hover:shadow-md transition-all"
                title="İndir">
            <i class="ph ph-download-simple text-2xl"></i>
        </button>

        <div class="w-px h-6 bg-gray-200"></div>

        <button onclick="copyToClipboard(`@Model.Ayet.Meal - @Model.Ayet.SureAdi @Model.Ayet.AyetNo`)"
                class="action-button group w-12 h-12 rounded-full bg-altin/10 text-altin flex items-center justify-center hover:bg-altin hover:text-white hover:shadow-md transition-all"
                title="Kopyala">
            <i class="ph ph-copy text-2xl"></i>
        </button>

    </div>

    <div class="w-full flex justify-between items-center mt-16 px-2">

        @if (Model.Ayet.Id > 1)
        {
            <a href="/Ayet/Detay/@(Model.Ayet.Id - 1)" class="nav-btn group">
                <i class="ph ph-arrow-left text-xl group-hover:-translate-x-1 transition-transform"></i>
                <span class="hidden sm:inline">Önceki Ayet</span>
            </a>
        }
        else
        {
            <div></div>
        }

        <a href="/Ayet/Detay/@(Model.Ayet.Id + 1)" class="nav-btn group">
            <span class="hidden sm:inline">Sonraki Ayet</span>
            <i class="ph ph-arrow-right text-xl group-hover:translate-x-1 transition-transform"></i>
        </a>
    </div>

</main>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script>
        function downloadAyet() {
            const shell = document.querySelector('.ayet-shell');
            if(shell) {
                // html2canvas blur desteklemediği için arkaplanı hafif krem rengi yapıyoruz, 
                // böylece şeffaf divin arkası düzgün gözükür.
                html2canvas(shell, {
                    backgroundColor: '#F7F7F4',
                    scale: 2
                }).then(canvas => {
                    const link = document.createElement('a');
                    link.download = `Ayet_@(Model.Ayet.SureAdi)_@(Model.Ayet.AyetNo).png`;
                    link.href = canvas.toDataURL('image/png');
                    link.click();
                });
            }
        }

        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(function() {
                // İkon değişimi feedback
                const btnIcon = document.querySelector('.ph-copy');
                if(btnIcon) {
                    btnIcon.classList.remove('ph-copy');
                    btnIcon.classList.add('ph-check');
                    setTimeout(() => {
                        btnIcon.classList.remove('ph-check');
                        btnIcon.classList.add('ph-copy');
                    }, 2000);
                }
            });
        }
    </script>
}