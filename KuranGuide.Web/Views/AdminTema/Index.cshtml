@model List<KuranGuide.Web.Models.TemaViewModel>

@{
    ViewData["Title"] = "Tema Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
    <div>
        <h1 class="text-3xl font-bold text-antrasit tracking-tight">Temalar</h1>
        <p class="text-gray-500 text-sm mt-1">Sistemdeki tüm başlıkları buradan yönetebilirsiniz.</p>
    </div>
    <a href="/Admin/AdminTema/Create"
       class="group flex items-center gap-2 bg-[#5A7D7C] text-white px-6 py-3 rounded-xl font-medium shadow-lg shadow-[#5A7D7C]/20 hover:bg-[#2C3E50] transition-all duration-300 hover:-translate-y-1">
        <i class="ph ph-plus-circle text-xl"></i>
        <span>Yeni Tema Ekle</span>
    </a>
</div>
@if (TempData["Success"] != null)
{
    <div id="alertBox"
         class="max-w-xxl mx-auto mt-6 bg-green-50 border border-green-300 text-green-800 px-4 py-3 rounded-xl
                shadow-lg text-center font-medium transition duration-300 opacity-100">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div id="alertBox"
         class="max-w-xxl mx-auto mt-6 bg-red-50 border border-red-300 text-red-800 px-4 py-3 rounded-xl
                shadow-lg text-center font-medium transition duration-300 opacity-100">
        @TempData["Error"]
    </div>
}
<div class="bg-white border border-gray-100 rounded-3xl shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] overflow-hidden">

    @if (Model == null || !Model.Any())
    {
        <div class="flex flex-col items-center justify-center py-20 text-center">
            <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mb-4 text-gray-300">
                <i class="ph ph-folder-dashed text-4xl"></i>
            </div>
            <h3 class="text-lg font-semibold text-antrasit">Henüz Tema Yok</h3>
            <p class="text-gray-400 text-sm max-w-xs mx-auto mt-2">Sisteme içerik eklemeye başlamak için yukarıdaki butonu kullanın.</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50/50 border-b border-gray-100 text-xs uppercase text-gray-500 font-semibold tracking-wider">
                        <th class="px-8 py-5">İkon</th>
                        <th class="px-6 py-5">Tema Bilgisi</th>
                        <th class="px-6 py-5">İstatistikler</th>
                        <th class="px-8 py-5 text-right">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model)
                    {
                        <tr class="group hover:bg-gray-50/80 transition-colors duration-200">
                            <td class="px-8 py-5">
                                <div class="w-12 h-12 rounded-2xl bg-white border border-gray-100 text-yaprak flex items-center justify-center text-2xl shadow-sm group-hover:scale-110 transition-transform duration-300 group-hover:border-yaprak/30 group-hover:text-antrasit">
                                    <i class="ph @(string.IsNullOrEmpty(item.Icon) ? "ph-hash" : item.Icon)"></i>
                                </div>
                            </td>

                            <td class="px-6 py-5">
                                <h4 class="text-base font-bold text-antrasit mb-1 group-hover:text-yaprak transition-colors">@item.TemaAdi</h4>
                                <p class="text-xs text-gray-400 line-clamp-1 max-w-xs">@item.Aciklama</p>
                            </td>

                            <td class="px-6 py-5">
                                <div class="flex items-center gap-2">
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-xs font-medium bg-blue-50 text-blue-600 border border-blue-100">
                                        <i class="ph ph-book-open"></i> @item.AyetSayisi Ayet
                                    </span>
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-xs font-medium bg-amber-50 text-amber-600 border border-amber-100">
                                        <i class="ph ph-quotes"></i> @item.HadisSayisi Hadis
                                    </span>
                                </div>
                            </td>

                            <td class="px-8 py-5 text-right">
                                <div class="flex items-center justify-end gap-2 opacity-80 group-hover:opacity-100 transition-opacity">
                                    <a href="/Admin/AdminTema/Edit?id=@item.Id"
                                       class="w-9 h-9 rounded-lg bg-white border border-gray-200 text-gray-500 flex items-center justify-center hover:border-blue-200 hover:bg-blue-50 hover:text-blue-600 transition-all"
                                       title="Düzenle">
                                        <i class="ph ph-pencil-simple text-lg"></i>
                                    </a>

                                    <a href="/Admin/AdminTema/Delete?id=@item.Id"
                                       onclick="return confirm('Bu temayı ve bağlı tüm kayıtları silmek istediğinize emin misiniz?')"
                                       class="w-9 h-9 rounded-lg bg-white border border-gray-200 text-gray-500 flex items-center justify-center hover:border-red-200 hover:bg-red-50 hover:text-red-600 transition-all"
                                       title="Sil">
                                        <i class="ph ph-trash text-lg"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<script>
    const alertBox = document.getElementById("alertBox");
    if (alertBox) {
        setTimeout(() => {
            alertBox.style.opacity = "0";
            alertBox.style.transform = "translateY(-10px)";
        }, 2000);

        setTimeout(() => {
            alertBox.remove();
        }, 2600);
    }
</script> 