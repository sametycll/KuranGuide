@model KuranGuide.Web.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Şifre Değiştir";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* 1. Arkaplan */
        body {
            background:
                radial-gradient(circle at 15% 20%, rgba(212, 175, 55, 0.035) 0%, transparent 45%),
                radial-gradient(circle at 85% 80%, rgba(90, 125, 124, 0.045) 0%, transparent 50%),
                #F7F7F4;
        }

        /* 2. Glass Form Kartı */
        .glass-form {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 32px;
            padding: 3rem;
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.05);
            position: relative;
            overflow: hidden;
        }

        /* Dekoratif Arkaplan İkonu */
        .card-bg-icon {
            position: absolute;
            top: -20px;
            right: -20px;
            font-size: 15rem;
            color: rgba(90, 125, 124, 0.03);
            pointer-events: none;
            z-index: 0;
        }

        /* Input Alanları */
        .form-input {
            background: rgba(255, 255, 255, 0.5);
            backdrop-filter: blur(4px);
            border: 1px solid rgba(0,0,0,0.1);
            transition: all 0.3s ease;
        }

        .form-input:focus {
            background: #ffffff;
            border-color: #5A7D7C; /* Yaprak */
            box-shadow: 0 0 0 4px rgba(90, 125, 124, 0.1);
        }
    </style>
}

<div class="max-w-2xl mx-auto py-16 px-4">

    <div class="mb-10 text-center relative z-10">
        <div class="w-20 h-20 bg-gradient-to-br from-yaprak/20 to-yaprak/5 text-yaprak rounded-full flex items-center justify-center mx-auto mb-6 shadow-inner border border-white/50">
            <i class="ph ph-lock-key text-4xl"></i>
        </div>
        <h1 class="font-serif text-4xl text-antrasit mb-2 font-medium">Güvenlik Ayarları</h1>
        <p class="text-gri font-light text-lg">Hesap güvenliğiniz için yeni şifrenizi belirleyin.</p>
    </div>

    <div class="glass-form">

        <i class="ph ph-shield-check card-bg-icon"></i>

        <div class="relative z-10">
            <h2 class="font-serif text-xl text-antrasit mb-8 flex items-center justify-center gap-2 opacity-80">
                <i class="ph ph-password text-yaprak text-2xl"></i>
                Şifre Yenileme
            </h2>

            <div asp-validation-summary="ModelOnly" class="mb-6 p-4 bg-red-50/80 backdrop-blur-sm text-red-600 rounded-xl text-sm border border-red-100 text-center"></div>

            <form method="post" action="/Profil/SifreDegistir">

                <div class="mb-6">
                    <label class="block text-sm font-bold text-antrasit mb-2 ml-1">Yeni Şifre</label>
                    <div class="relative group">
                        <input asp-for="NewPassword" type="password" placeholder="En az 6 karakter"
                               class="form-input w-full p-4 pl-12 rounded-xl outline-none text-antrasit placeholder-gray-400" />
                        <i class="ph ph-key absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-xl group-focus-within:text-yaprak transition-colors"></i>
                    </div>
                    <span asp-validation-for="NewPassword" class="text-xs text-red-500 mt-1 block pl-1 font-medium"></span>
                </div>

                <div class="mb-8">
                    <label class="block text-sm font-bold text-antrasit mb-2 ml-1">Yeni Şifre (Tekrar)</label>
                    <div class="relative group">
                        <input asp-for="ConfirmNewPassword" type="password" placeholder="••••••••"
                               class="form-input w-full p-4 pl-12 rounded-xl outline-none text-antrasit placeholder-gray-400" />
                        <i class="ph ph-check-circle absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-xl group-focus-within:text-yaprak transition-colors"></i>
                    </div>
                    <span asp-validation-for="ConfirmNewPassword" class="text-xs text-red-500 mt-1 block pl-1 font-medium"></span>
                </div>

                <div class="flex items-center justify-between gap-4 pt-6 border-t border-gray-100/50">
                    <a href="/Profil" class="px-6 py-3 rounded-xl text-gray-500 font-medium hover:bg-white hover:text-antrasit hover:shadow-sm transition-all">
                        İptal Et
                    </a>
                    <button type="submit" class="px-8 py-3 bg-yaprak text-white rounded-xl font-semibold shadow-lg shadow-yaprak/20 hover:bg-yaprak/90 hover:-translate-y-0.5 transition-all flex items-center gap-2">
                        <i class="ph ph-floppy-disk text-lg"></i>
                        Kaydet
                    </button>
                </div>
            </form>
        </div>

    </div>
</div>