@{
    ViewData["Title"] = "Profilim";

    // Çerezlerden bilgileri al
    var email = Context.Request.Cookies["email"];
    var fullName = Context.Request.Cookies["fullname"] ?? email?.Split('@')[0] ?? "Misafir";
    var firstLetter = !string.IsNullOrEmpty(fullName) ? fullName.Substring(0, 1).ToUpper() : "U";
}

@section Styles {
    <style>
        /* 1. Arkaplan */
        body {
            background:
                radial-gradient(circle at 15% 20%, rgba(212, 175, 55, 0.035) 0%, transparent 45%),
                radial-gradient(circle at 85% 80%, rgba(90, 125, 124, 0.045) 0%, transparent 50%),
                #F7F7F4;
        }

        /* 2. Profil Kartı (Glassmorphism) */
        .profile-card {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 32px;
            padding: 3rem;
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.05);
            position: relative;
            overflow: hidden;
        }

        /* Dekoratif Arkaplan İkonu */
        .card-bg-icon {
            position: absolute;
            top: -20px;
            right: -20px;
            font-size: 15rem;
            color: rgba(90, 125, 124, 0.03);
            pointer-events: none;
            z-index: 0;
        }

        /* 3. Menü Linkleri */
        .action-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.2rem 1.5rem;
            background: white;
            border: 1px solid #f3f4f6;
            border-radius: 16px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            z-index: 10;
        }

        .action-row:hover {
            transform: translateY(-2px);
            border-color: #D4AF37; /* Altın */
            box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);
        }

        .icon-box {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            transition: all 0.3s ease;
        }
    </style>
}

<section class="max-w-2xl mx-auto px-4 py-20">

    <div class="profile-card">

        <i class="ph ph-user-circle card-bg-icon"></i>

        <div class="relative z-10 flex flex-col items-center text-center mb-12">

            <div class="w-28 h-28 rounded-full bg-gradient-to-br from-yaprak to-[#4A6A69] p-1 shadow-xl shadow-yaprak/20 mb-5">
                <div class="w-full h-full rounded-full bg-white/10 backdrop-blur-sm border-2 border-white flex items-center justify-center text-4xl font-serif font-bold text-white">
                    @firstLetter
                </div>
            </div>

            <h2 class="font-serif text-3xl text-antrasit font-bold mb-1">@fullName</h2>
            <p class="text-gri font-medium flex items-center gap-2 bg-white/50 px-4 py-1 rounded-full border border-gray-100">
                <i class="ph ph-envelope-simple"></i> @email
            </p>
        </div>

        <div class="relative z-10 space-y-4">

            <a href="/Favori" class="action-row group">
                <div class="flex items-center gap-4">
                    <div class="icon-box bg-red-50 text-red-400 group-hover:bg-red-500 group-hover:text-white">
                        <i class="ph ph-heart"></i>
                    </div>
                    <div>
                        <h4 class="font-bold text-antrasit text-lg">Favorilerim</h4>
                        <p class="text-xs text-gray-400">Kaydettiğiniz ayet ve hadisler</p>
                    </div>
                </div>
                <i class="ph ph-caret-right text-gray-300 text-xl group-hover:text-red-500 transition-colors"></i>
            </a>

            <a href="/Profil/SifreDegistir" class="action-row group">
                <div class="flex items-center gap-4">
                    <div class="icon-box bg-blue-50 text-blue-400 group-hover:bg-blue-500 group-hover:text-white">
                        <i class="ph ph-lock-key"></i>
                    </div>
                    <div>
                        <h4 class="font-bold text-antrasit text-lg">Güvenlik</h4>
                        <p class="text-xs text-gray-400">Şifre güncelleme işlemleri</p>
                    </div>
                </div>
                <i class="ph ph-caret-right text-gray-300 text-xl group-hover:text-blue-500 transition-colors"></i>
            </a>

            <a href="/Auth/Logout" class="action-row group hover:!border-red-200 hover:!bg-red-50/50 mt-8">
                <div class="flex items-center gap-4">
                    <div class="icon-box bg-gray-100 text-gray-500 group-hover:bg-red-500 group-hover:text-white">
                        <i class="ph ph-sign-out"></i>
                    </div>
                    <div>
                        <h4 class="font-bold text-gray-600 group-hover:text-red-600 transition-colors">Oturumu Kapat</h4>
                    </div>
                </div>
                <i class="ph ph-caret-right text-gray-300 text-xl group-hover:text-red-500 transition-colors"></i>
            </a>

        </div>
    </div>

    <div class="text-center mt-8 text-gray-400 text-xs">
        <p>Üyelik Tarihi: @DateTime.Now.ToString("MMMM yyyy")</p>
    </div>

</section>