@model KuranGuide.Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}




<section class="min-h-screen flex items-center justify-center px-4 py-12">

    <div class="w-full max-w-md bg-white/80 backdrop-blur-md border border-gray-100
                shadow-[0_10px_40px_-20px_rgba(0,0,0,0.08)] rounded-3xl p-10">

        <div class="text-center mb-8">
            <div class="w-16 h-16 rounded-full bg-yaprak/10 text-yaprak
                        flex items-center justify-center mx-auto mb-4">
                <i class="ph ph-user-circle text-4xl"></i>
            </div>

            <h2 class="font-serif text-3xl text-antrasit mb-2">Giriş Yap</h2>
            <p class="text-gri text-sm">Favorilere eklemek ve daha fazlası için giriş yapın</p>
        </div>
      @*   @if (TempData["Error"] != null)
        {
        <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-700 rounded-xl 
                flex items-center gap-3 shadow-sm">
            <i class="ph ph-warning text-xl"></i>
            <span>@TempData["Error"]</span>
        </div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="mb-6 p-4 bg-green-50 border border-green-200 text-green-700 rounded-xl
                flex items-center gap-3 shadow-sm">
                <i class="ph ph-check-circle text-xl"></i>
                <span>@TempData["Success"]</span>
            </div>
        } *@

        <form method="post" action="/Auth/Login">

            <div class="mb-5">
                <label class="block text-sm mb-1 text-antrasit font-semibold">E-Posta</label>
                <input asp-for="Email"
                       class="w-full p-4 rounded-xl border border-gray-200 focus:ring-2
                              focus:ring-yaprak/40 focus:border-yaprak transition bg-white"
                       placeholder="ornek@mail.com" />
            </div>

            <div class="mb-6">
                <label class="block text-sm mb-1 text-antrasit font-semibold">Şifre</label>
                <input asp-for="Password" type="password"
                       class="w-full p-4 rounded-xl border border-gray-200 focus:ring-2
                              focus:ring-yaprak/40 focus:border-yaprak transition bg-white"
                       placeholder="••••••••" />
            </div>

            <button class="w-full bg-yaprak text-white py-3.5 rounded-xl text-lg
                           hover:bg-yaprak/90 transition shadow-md shadow-yaprak/20">
                Giriş Yap
            </button>

            <p class="text-center text-sm text-gri mt-6">
                Hesabın yok mu?
                <a href="/Auth/Register" class="text-yaprak font-medium hover:underline">
                    Kayıt Ol
                </a>
            </p>

        </form>
    </div>

</section>
