@model List<KuranGuide.Web.Models.KullaniciViewModel>

@{
    ViewData["Title"] = "Kullanıcı Yönetimi";

    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
 

<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
    <div>
        <h1 class="text-3xl font-bold text-[#2C3E50] tracking-tight">Kullanıcılar</h1>
        <p class="text-gray-500 text-sm mt-1">Sistemdeki kayıtlı üyeleri ve yetkilerini yönetin.</p>
    </div>

    <a href="/Admin/AdminKullanici/Create"
       class="group flex items-center gap-2 bg-[#2C3E50] text-white px-6 py-3 rounded-xl font-medium shadow-lg shadow-[#2C3E50]/20 hover:bg-[#1a252f] transition-all duration-300 hover:-translate-y-1">
        <i class="ph ph-user-plus text-xl"></i>
        <span>Yeni Kullanıcı</span>
    </a>
</div>
@if (TempData["Success"] != null)
{
    <div id="alertBox"
         class="max-w-xxl mx-auto mt-6 bg-green-50 border border-green-300 text-green-800 px-4 py-3 rounded-xl
                shadow-lg text-center font-medium transition duration-300 opacity-100">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div id="alertBox"
         class="max-w-xxl mx-auto mt-6 bg-red-50 border border-red-300 text-red-800 px-4 py-3 rounded-xl
                shadow-lg text-center font-medium transition duration-300 opacity-100">
        @TempData["Error"]
    </div>
}

<div class="bg-white border border-gray-100 rounded-3xl shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] overflow-hidden">

    @if (Model == null || !Model.Any())
    {
        <div class="flex flex-col items-center justify-center py-20 text-center">
            <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mb-4 text-gray-300">
                <i class="ph ph-users text-4xl"></i>
            </div>
            <h3 class="text-lg font-semibold text-[#2C3E50]">Kullanıcı Bulunamadı</h3>
            <p class="text-gray-400 text-sm max-w-xs mx-auto mt-2">Yeni bir kullanıcı eklemek için butonu kullanın.</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50/50 border-b border-gray-100 text-xs uppercase text-gray-500 font-semibold tracking-wider">
                        <th class="px-6 py-5">Kullanıcı</th>
                        <th class="px-6 py-5">Rol / Yetki</th>
                        <th class="px-6 py-5">Kayıt Tarihi</th>
                        <th class="px-8 py-5 text-right">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model)
                    {
                        <tr class="group hover:bg-gray-50/80 transition-colors duration-200">

                            <td class="px-6 py-5">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-[#2C3E50]/5 text-[#2C3E50] flex items-center justify-center font-bold text-lg border border-[#2C3E50]/10">
                                        @(item.Email.Substring(0, 1).ToUpper())
                                    </div>
                                    <div>
                                        <div class="text-sm font-bold text-[#2C3E50]">@item.Email</div>
                                        <div class="text-xs text-gray-400">ID: @item.Id</div>
                                    </div>
                                </div>
                            </td>

                            <td class="px-6 py-5">
                                @if (item.Role == "Admin")
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-xs font-bold bg-red-50 text-red-600 border border-red-100">
                                        <i class="ph ph-shield-check text-lg"></i> Yönetici
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-xs font-medium bg-blue-50 text-blue-600 border border-blue-100">
                                        <i class="ph ph-user"></i> Üye
                                    </span>
                                }
                            </td>

                            <td class="px-6 py-5">
                                <div class="text-sm text-gray-600">
                                    @item.CreatedAt.ToString("dd MMM yyyy")
                                </div>
                                <div class="text-xs text-gray-400">
                                    @item.CreatedAt.ToString("HH:mm")
                                </div>
                            </td>

                            <td class="px-8 py-5 text-right">
                                <div class="flex items-center justify-end gap-2 opacity-80 group-hover:opacity-100 transition-opacity">
                                    <a href="/Admin/AdminKullanici/Edit?id=@item.Id"
                                       class="w-9 h-9 rounded-lg bg-white border border-gray-200 text-gray-500 flex items-center justify-center hover:border-blue-200 hover:bg-blue-50 hover:text-blue-600 transition-all"
                                       title="Düzenle">
                                        <i class="ph ph-pencil-simple text-lg"></i>
                                    </a>

                                    <a href="/Admin/AdminKullanici/Delete?id=@item.Id"
                                       onclick="return confirm('Bu kullanıcıyı silmek istediğinize emin misiniz?')"
                                       class="w-9 h-9 rounded-lg bg-white border border-gray-200 text-gray-500 flex items-center justify-center hover:border-red-200 hover:bg-red-50 hover:text-red-600 transition-all"
                                       title="Sil">
                                        <i class="ph ph-trash text-lg"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<script>
    const alertBox = document.getElementById("alertBox");
    if (alertBox) {
        setTimeout(() => {
            alertBox.style.opacity = "0";
            alertBox.style.transform = "translateY(-10px)";
        }, 2000);

        setTimeout(() => {
            alertBox.remove();
        }, 2600);
    }
</script> 