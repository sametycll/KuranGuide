@model KuranGuide.Web.Models.KullaniciViewModel

@{
    ViewData["Title"] = "Yeni Kullanıcı Ekle";

    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="flex items-center gap-4 mb-8">
    <a href="/Admin/AdminKullanici/Index" class="w-10 h-10 rounded-xl bg-white border border-gray-200 flex items-center justify-center text-gray-500 hover:text-[#2C3E50] hover:border-[#2C3E50] transition-all">
        <i class="ph ph-arrow-left text-xl"></i>
    </a>
    <div>
        <h1 class="text-2xl font-bold text-[#2C3E50]">Yeni Kullanıcı</h1>
        <p class="text-sm text-gray-500">Sisteme manuel olarak bir üye veya yönetici ekleyin.</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

    <div class="lg:col-span-2">
        <form method="post" class="bg-white border border-gray-100 rounded-3xl p-8 shadow-sm relative">
            <div class="space-y-6">

                <div>
                    <label class="block text-sm font-semibold text-[#2C3E50] mb-2">E-Posta Adresi</label>
                    <div class="relative">
                        <i class="ph ph-envelope absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-lg"></i>
                        <input asp-for="Email" type="email" id="emailInput" placeholder="ornek@mail.com" required
                               class="w-full pl-11 pr-5 py-3.5 rounded-xl border border-gray-200 bg-gray-50/50 focus:bg-white focus:border-[#2C3E50] focus:ring-4 focus:ring-[#2C3E50]/10 outline-none transition-all" />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-[#2C3E50] mb-2">Şifre</label>
                    <div class="relative">
                        <i class="ph ph-lock-key absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-lg"></i>
                        <input asp-for="Password" type="password" placeholder="••••••••" required
                               class="w-full pl-11 pr-5 py-3.5 rounded-xl border border-gray-200 bg-gray-50/50 focus:bg-white focus:border-[#2C3E50] focus:ring-4 focus:ring-[#2C3E50]/10 outline-none transition-all" />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-[#2C3E50] mb-2">Yetki Rolü</label>
                    <div class="relative">
                        <i class="ph ph-shield-check absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-lg"></i>
                        <select asp-for="Role" id="roleInput"
                                class="w-full pl-11 pr-10 py-3.5 rounded-xl border border-gray-200 bg-gray-50/50 focus:bg-white focus:border-[#2C3E50] focus:ring-4 focus:ring-[#2C3E50]/10 outline-none transition-all appearance-none cursor-pointer">
                            <option value="User">User (Standart Üye)</option>
                            <option value="Admin">Admin (Tam Yetki)</option>
                        </select>
                        <i class="ph ph-caret-down absolute right-5 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                    </div>
                </div>

                <div class="pt-6 border-t border-gray-100 flex items-center justify-end gap-3">
                    <a href="/Admin/AdminKullanici/Index" class="px-6 py-3 rounded-xl text-gray-500 hover:bg-gray-50 transition font-medium">İptal</a>
                    <button type="submit" class="bg-[#2C3E50] text-white px-8 py-3 rounded-xl font-medium shadow-lg shadow-[#2C3E50]/20 hover:bg-[#1a252f] hover:scale-[1.02] active:scale-95 transition-all duration-200">
                        Oluştur
                    </button>
                </div>

            </div>
        </form>
    </div>

    <div class="lg:col-span-1">

        <h3 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4 pl-1">Profil Önizleme</h3>

        <div class="bg-white rounded-3xl border border-gray-200 p-8 shadow-sm text-center relative overflow-hidden">

            <div class="absolute top-0 left-0 w-full h-24 bg-gradient-to-br from-[#2C3E50] to-[#34495E]"></div>

            <div class="w-20 h-20 mx-auto bg-white p-1.5 rounded-full relative z-10 shadow-md mb-4">
                <div class="w-full h-full bg-gray-100 rounded-full flex items-center justify-center text-3xl font-bold text-[#2C3E50]">
                    <span id="avatarLetter">?</span>
                </div>
            </div>

            <h3 id="emailPreview" class="text-lg font-bold text-[#2C3E50] mb-1 truncate">
                ornek@mail.com
            </h3>

            <span id="roleBadge" class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-600 mb-6">
                User
            </span>

            <div class="flex justify-center gap-4 text-sm text-gray-500 border-t border-gray-100 pt-4">
                <div class="flex flex-col">
                    <span class="font-bold text-[#2C3E50]">0</span>
                    <span class="text-xs">Favori</span>
                </div>
                <div class="w-px h-8 bg-gray-200"></div>
                <div class="flex flex-col">
                    <span class="font-bold text-[#2C3E50]">Bugün</span>
                    <span class="text-xs">Katıldı</span>
                </div>
            </div>
        </div>
        @if (TempData["Error"] != null)
        {
            <div id="alertBox"
                 class="max-w-md mx-auto mt-6 bg-red-50 border border-red-300 text-red-800 px-4 py-3 rounded-xl
                shadow-lg text-center font-medium transition duration-300 opacity-100">
                @TempData["Error"]
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const emailInput = document.getElementById('emailInput');
        const roleInput = document.getElementById('roleInput');
        const emailPreview = document.getElementById('emailPreview');
        const avatarLetter = document.getElementById('avatarLetter');
        const roleBadge = document.getElementById('roleBadge');

        // Email değiştikçe
        emailInput.addEventListener('input', function () {
            const val = this.value || 'ornek@mail.com';
            emailPreview.textContent = val;
            avatarLetter.textContent = val.charAt(0).toUpperCase();
        });

        // Rol değiştikçe badge rengi
        roleInput.addEventListener('change', function () {
            const role = this.value;
            roleBadge.textContent = role;

            if (role === 'Admin') {
                roleBadge.className = 'inline-block px-3 py-1 rounded-full text-xs font-medium bg-red-50 text-red-600 mb-6';
            } else {
                roleBadge.className = 'inline-block px-3 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-600 mb-6';
            }
        });


                    const alertBox = document.getElementById("alertBox");
                    if (alertBox) {
                        setTimeout(() => {
                            alertBox.style.opacity = "0";
                            alertBox.style.transform = "translateY(-10px)";
                        }, 2000);

                        setTimeout(() => {
                            alertBox.remove();
                        }, 2600);
                    }

    </script>
}

