@model KuranGuide.Application.DTOs.Ayet.AyetCreateDto

@{
    ViewData["Title"] = "Yeni Ayet Ekle";

    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="flex items-center gap-4 mb-8">
    <a href="/Admin/AdminAyet/Index" class="w-10 h-10 rounded-xl bg-white border border-gray-200 flex items-center justify-center text-gray-500 hover:text-[#5A7D7C] hover:border-[#5A7D7C] transition-all">
        <i class="ph ph-arrow-left text-xl"></i>
    </a>
    <div>
        <h1 class="text-2xl font-bold text-[#2C3E50]">Yeni Ayet Ekle</h1>
        <p class="text-sm text-gray-500">Veritabanına yeni bir ayet kaydedin.</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

    <div class="lg:col-span-2">
        <form method="post" class="bg-white border border-gray-100 rounded-3xl p-8 shadow-sm relative">
            <div class="space-y-6">

                <div>
                    <label class="block text-sm font-semibold text-[#2C3E50] mb-2">İlgili Tema</label>
                    <div class="relative">
                        <select asp-for="TemaId" asp-items="ViewBag.Temalar" required
                                class="w-full px-5 py-3.5 rounded-xl border border-gray-200 bg-gray-50/50 focus:bg-white focus:border-[#5A7D7C] focus:ring-4 focus:ring-[#5A7D7C]/10 outline-none transition-all appearance-none cursor-pointer">
                            <option value="" disabled selected>Tema Seçiniz...</option>
                        </select>
                        <i class="ph ph-caret-down absolute right-5 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold text-[#2C3E50] mb-2">Sure No</label>
                        <input asp-for="SureId" type="number" id="sureInput" placeholder="Örn: 2" required
                               class="w-full px-5 py-3.5 rounded-xl border border-gray-200 bg-gray-50/50 focus:bg-white focus:border-[#5A7D7C] focus:ring-4 focus:ring-[#5A7D7C]/10 outline-none transition-all" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-[#2C3E50] mb-2">Ayet No</label>
                        <input asp-for="AyetNo" type="number" id="ayetInput" placeholder="Örn: 255" required
                               class="w-full px-5 py-3.5 rounded-xl border border-gray-200 bg-gray-50/50 focus:bg-white focus:border-[#5A7D7C] focus:ring-4 focus:ring-[#5A7D7C]/10 outline-none transition-all" />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-[#2C3E50] mb-2 flex justify-between">
                        Arapça Metin
                        <span class="text-xs font-normal text-gray-400">Amiri Font</span>
                    </label>
                    <textarea asp-for="ArapcaMetin" rows="4" dir="rtl" id="arapcaInput" required
                              class="w-full px-5 py-3.5 rounded-xl border border-gray-200 bg-gray-50/50 focus:bg-white focus:border-[#5A7D7C] focus:ring-4 focus:ring-[#5A7D7C]/10 outline-none transition-all font-arabic text-xl resize-none leading-loose"
                              placeholder="Buraya Arapça metni yapıştırın..."></textarea>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-[#2C3E50] mb-2">Türkçe Meal</label>
                    <textarea asp-for="Meal" rows="3" id="mealInput" required
                              class="w-full px-5 py-3.5 rounded-xl border border-gray-200 bg-gray-50/50 focus:bg-white focus:border-[#5A7D7C] focus:ring-4 focus:ring-[#5A7D7C]/10 outline-none transition-all resize-none"
                              placeholder="Ayetin anlamını yazın..."></textarea>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-[#2C3E50] mb-2">Kısa Tefsir / Açıklama</label>
                    <textarea asp-for="Aciklama" rows="4" required
                              class="w-full px-5 py-3.5 rounded-xl border border-gray-200 bg-gray-50/50 focus:bg-white focus:border-[#5A7D7C] focus:ring-4 focus:ring-[#5A7D7C]/10 outline-none transition-all resize-none"
                              placeholder="Varsa kısa bir açıklama veya tefsir..."></textarea>
                </div>

                <div class="pt-6 border-t border-gray-100 flex items-center justify-end gap-3">
                    <a href="/admin/ayet" class="px-6 py-3 rounded-xl text-gray-500 hover:bg-gray-50 transition font-medium">İptal</a>
                    <button type="submit" class="bg-[#5A7D7C] text-white px-8 py-3 rounded-xl font-medium shadow-lg shadow-[#5A7D7C]/20 hover:bg-[#2C3E50] hover:scale-[1.02] active:scale-95 transition-all duration-200">
                        Kaydet
                    </button>
                </div>

            </div>
        </form>
    </div>

    <div class="lg:col-span-1">
        <h3 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4 pl-1">Canlı Önizleme</h3>

        <div class="bg-white rounded-3xl border border-[#5A7D7C]/20 p-8 shadow-sm relative overflow-hidden group text-center">

            <span id="badgePreview" class="inline-block px-3 py-1 bg-[#5A7D7C]/10 text-[#5A7D7C] rounded-lg text-xs font-bold tracking-wide mb-6">
                1. Sûre, 1. Ayet
            </span>

            <p id="arapcaPreview" class="font-arabic text-2xl md:text-3xl leading-loose text-[#2C3E50] mb-6" dir="rtl">
                بسم الله الرحمن الرحيم
            </p>

            <div class="w-16 h-0.5 bg-gray-100 mx-auto mb-6"></div>

            <p id="mealPreview" class="text-gray-600 font-serif italic leading-relaxed">
                Rahmân ve Rahîm olan Allah'ın adıyla.
            </p>

            <div class="mt-8 pt-4 border-t border-gray-50 flex justify-center text-xs text-gray-300 font-medium">
                Kart Görünümü
            </div>
        </div>

        <div class="mt-6 bg-amber-50 text-amber-800 p-4 rounded-xl text-sm border border-amber-100 flex gap-3 items-start">
            <i class="ph ph-warning-circle text-lg mt-0.5"></i>
            <div>
                <strong>Dikkat:</strong> Arapça metinleri kopyalarken harekelerin (üstün, esre vb.) doğru geldiğinden emin olun.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // DOM Elements
        const sureInput = document.getElementById('sureInput');
        const ayetInput = document.getElementById('ayetInput');
        const arapcaInput = document.getElementById('arapcaInput');
        const mealInput = document.getElementById('mealInput');

        const badgePreview = document.getElementById('badgePreview');
        const arapcaPreview = document.getElementById('arapcaPreview');
        const mealPreview = document.getElementById('mealPreview');

        // Update Functions
        function updateBadge() {
            const sure = sureInput.value || '?';
            const ayet = ayetInput.value || '?';
            badgePreview.textContent = `${sure}. Sûre, ${ayet}. Ayet`;
        }

        // Listeners
        sureInput.addEventListener('input', updateBadge);
        ayetInput.addEventListener('input', updateBadge);

        arapcaInput.addEventListener('input', function() {
            arapcaPreview.textContent = this.value || '...';
        });

        mealInput.addEventListener('input', function() {
            mealPreview.textContent = this.value || '...';
        });
    </script>
}

