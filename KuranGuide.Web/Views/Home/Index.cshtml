@model HomePageViewModel
@{
    ViewData["Title"] = "Ana Sayfa";
    // Navbar'ın şeffaf olması için bu sayfaya özel bir ayar gerekebilir,
    // şimdilik mevcut navbar ile uyumlu modern bir yapı kuruyoruz.
}

@section Styles {
    <style>
        /* HERO SECTION: Arka plan resmi */
        .hero-section {
            position: relative;
            /* Unsplash'ten huzurlu bir İslami mimari görseli */
            background-image: url('https://images.unsplash.com/photo-1584551246679-0daf3d275d0f?q=80&w=2000&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            background-attachment: fixed; /* Parallax efekti */
            height: 500px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-bottom-left-radius: 40px;
            border-bottom-right-radius: 40px;
        }

        /* Resmin üzerine gelen koyu perde */
        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(44, 62, 80, 0.7), rgba(44, 62, 80, 0.4));
            border-bottom-left-radius: 40px;
            border-bottom-right-radius: 40px;
        }

        /* Cam Efektli Arama Kutusu */
        .glass-search-container {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 24px;
            padding: 3rem 2rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            max-width: 800px;
            width: 90%;
            z-index: 10;
        }

        /* Duygu Etiketleri */
        .mood-tag {
            background: rgba(255, 255, 255, 0.2);
            color: white;
            padding: 8px 16px;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.3s ease;
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

            .mood-tag:hover {
                background: #D4AF37; /* Altın */
                color: white;
                transform: translateY(-2px);
                border-color: #D4AF37;
            }

    /* Kartları yukarı kaydırmak için */
        .content-overlap {
            /* MOBİL İÇİN AYAR: */
            margin-top: 20px; /* Mobilde kartları biraz aşağı itiyoruz (Boşluk oluşur) */
            position: relative;
            z-index: 20;
            padding-bottom: 4rem;
        }

        /* MASAÜSTÜ İÇİN AYAR (Tablet ve üzeri): */
         @@media (min-width: 768px) {
            .content-overlap {
                margin-top: -80px; /* Masaüstünde tekrar yukarı çekip resmin üstüne bindiriyoruz */
            }
        }

        /* Kart Animasyonları */
        .fade-in-up {
            animation: fadeInUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Premium Card Güncellemesi */
        .premium-card {
            background: #ffffff;
            border-radius: 24px;
            border: 1px solid #f0f0f0;
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.05);
            padding: 2rem;
            height: 100%;
            transition: all 0.3s ease;
        }

            .premium-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 25px 50px -12px rgba(212, 175, 55, 0.15); /* Altın gölge */
                border-color: #D4AF37;
            }

        .arabic-text {
            font-family: var(--arabic-font), serif;
            line-height: 2;
        }
    </style>
}

<section class="hero-section">
    <div class="hero-overlay"></div>

    <div class="glass-search-container text-center fade-in-up">
        <h1 class="font-serif text-3xl md:text-5xl text-white mb-4 font-medium tracking-wide">
            Ruhun neye ihtiyaç duyuyor?
        </h1>
        <p class="text-gray-200 mb-8 text-lg font-light">Kur'an'ın rehberliğinde huzuru ve cevapları keşfet.</p>

        <form method="get" action="/Arama" class="relative group max-w-lg mx-auto mb-8">
            <input type="text" name="q" placeholder="Kelime, duygu veya ayet ara..."
                   class="w-full py-4 px-7 rounded-full bg-white text-antrasit shadow-xl
                          focus:ring-4 focus:ring-altin/30 outline-none text-base placeholder:text-gray-400">

            <button class="absolute right-2 top-1/2 -translate-y-1/2 w-11 h-11 bg-yaprak text-white
                           rounded-full flex items-center justify-center hover:bg-yaprak/90 transition-all">
                <i class="ph ph-magnifying-glass text-lg"></i>
            </button>
        </form>

        <div class="flex flex-wrap justify-center gap-3">
            <span class="text-white/80 text-sm py-2 mr-2">Hızlı Keşfet:</span>
            <a href="/Arama?q=huzur" class="mood-tag">Huzur</a>
            <a href="/Arama?q=sabr" class="mood-tag">Sabır</a>
            <a href="/Arama?q=şükür" class="mood-tag">Şükür</a>
            <a href="/Arama?q=korku" class="mood-tag">Endişe</a>
            <a href="/Arama?q=cennet" class="mood-tag">Umut</a>
        </div>
    </div>
</section>


<div class="max-w-6xl mx-auto px-4 content-overlap">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <div class="fade-in-up" style="animation-delay: 0.1s;">
            <div class="premium-card relative group">
                <i class="ph ph-book-open-text absolute right-4 top-4 text-9xl text-gray-50 opacity-50 group-hover:text-yaprak/10 transition-colors"></i>

                <div class="relative z-10 flex flex-col h-full">
                    <div class="flex justify-between items-center mb-6">
                        <span class="bg-yaprak/10 text-yaprak px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest">
                            Günün Ayeti
                        </span>

                        <button class="favori-toggle w-10 h-10 rounded-full bg-gray-50 flex items-center justify-center hover:bg-red-50 transition-colors"
                                data-type="ayet" data-refid="@Model.GununAyeti?.Id">
                            <i class="ph ph-heart text-xl @(Model.IsFavoritedAyet ? "ph-fill text-red-500" : "text-gray-300")"></i>
                        </button>
                    </div>

                    @if (Model.GununAyeti != null)
                    {
                        <div class="flex-grow">
                            <p class="arabic-text text-3xl md:text-4xl text-right text-antrasit mb-6" dir="rtl">
                                @Model.GununAyeti.ArapcaMetin
                            </p>
                            <p class="font-serif text-lg text-gray-600 leading-relaxed">
                                "@Model.GununAyeti.Meal"
                            </p>
                        </div>

                        <div class="mt-6 pt-6 border-t border-gray-100 flex justify-between items-center">
                            <div>
                                <h4 class="font-bold text-antrasit">@Model.GununAyeti.SureAdi Suresi</h4>
                                <span class="text-sm text-gray-400">@Model.GununAyeti.AyetNo. Ayet</span>
                            </div>
                            <a href="/Ayet/Detay/@Model.GununAyeti.Id" class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center text-gray-400 hover:border-yaprak hover:text-yaprak hover:bg-yaprak/5 transition-all">
                                <i class="ph ph-arrow-right"></i>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="fade-in-up" style="animation-delay: 0.2s;">
            <div class="premium-card relative group">
                <i class="ph ph-quotes absolute right-4 top-4 text-9xl text-gray-50 opacity-50 group-hover:text-altin/10 transition-colors"></i>

                <div class="relative z-10 flex flex-col h-full">
                    <div class="flex justify-between items-center mb-6">
                        <span class="bg-altin/10 text-altin px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest">
                            Günün Hadisi
                        </span>

                        <button class="favori-toggle w-10 h-10 rounded-full bg-gray-50 flex items-center justify-center hover:bg-red-50 transition-colors"
                                data-type="hadis" data-refid="@Model.GununHadisi?.Id">
                            <i class="ph ph-heart text-xl @(Model.IsFavoritedHadis ? "ph-fill text-red-500" : "text-gray-300")"></i>
                        </button>
                    </div>

                    @if (Model.GununHadisi != null)
                    {
                        <div class="flex-grow flex items-center">
                            <p class="font-serif text-xl md:text-2xl text-antrasit/80 italic leading-relaxed text-center w-full">
                                "@Model.GununHadisi.Metin"
                            </p>
                        </div>

                        <div class="mt-6 pt-6 border-t border-gray-100 flex justify-between items-center">
                            <div>
                                <h4 class="font-bold text-antrasit">Hadis-i Şerif</h4>
                                <span class="text-sm text-gray-400">@Model.GununHadisi.Kaynak</span>
                            </div>
                            <a href="/Hadis/Detay/@Model.GununHadisi.Id" class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center text-gray-400 hover:border-altin hover:text-altin hover:bg-altin/5 transition-all">
                                <i class="ph ph-arrow-right"></i>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>

    <div class="mt-16 text-center fade-in-up" style="animation-delay: 0.3s;">
        <h3 class="font-serif text-2xl text-antrasit mb-8 relative inline-block">
            Popüler Konular
            <span class="absolute -bottom-2 left-0 w-full h-1 bg-gradient-to-r from-transparent via-yaprak/30 to-transparent"></span>
        </h3>

        <div class="flex flex-wrap justify-center gap-4">
            @if (Model.PopulerTemalar != null)
            {
                @foreach (var tema in Model.PopulerTemalar)
                {
                    <a href="/Temalar/Detay/@tema.Id"
                       class="group bg-white px-6 py-3 rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-gray-50 text-gray-500 flex items-center justify-center group-hover:bg-altin group-hover:text-white transition-colors">
                            <i class="ph ph-hash"></i>
                        </div>
                        <span class="font-medium text-gray-700 group-hover:text-antrasit">@tema.TemaAdi</span>
                    </a>
                }
            }
        </div>
    </div>

</div>