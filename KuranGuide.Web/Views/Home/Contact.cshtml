@{
    ViewData["Title"] = "İletişim";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* 1. Arkaplan */
        body {
            background:
                radial-gradient(circle at 15% 20%, rgba(212, 175, 55, 0.035) 0%, transparent 45%),
                radial-gradient(circle at 85% 80%, rgba(90, 125, 124, 0.045) 0%, transparent 50%),
                #F7F7F4;
        }

        /* 2. Sol Taraf: Bilgi Kartı */
        .info-card {
            background: linear-gradient(135deg, #5A7D7C, #2C3E50);
            color: white;
            border-radius: 24px;
            padding: 3rem;
            position: relative;
            overflow: hidden;
            box-shadow: 0 20px 40px -10px rgba(44, 62, 80, 0.25);
        }

        /* Dekoratif Desen */
        .pattern-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(rgba(255,255,255,0.1) 1px, transparent 1px);
            background-size: 20px 20px;
            opacity: 0.3;
            pointer-events: none;
        }

        /* 3. Sağ Taraf: Form (Glassmorphism) */
        .form-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 24px;
            padding: 3rem;
            box-shadow: 0 10px 30px -10px rgba(0,0,0,0.05);
        }

        /* Input Alanları */
        .form-input {
            background: rgba(255, 255, 255, 0.5);
            border: 1px solid rgba(0,0,0,0.1);
            transition: all 0.3s ease;
        }

        .form-input:focus {
            background: #ffffff;
            border-color: #D4AF37; /* Altın */
            box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.1);
        }

        /* Sosyal Medya İkonları */
        .social-btn {
            width: 45px;
            height: 45px;
            border-radius: 12px;
            background: rgba(255,255,255,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            color: white;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .social-btn:hover {
            background: white;
            color: #5A7D7C;
            transform: translateY(-3px);
        }
    </style>
}

<div class="max-w-6xl mx-auto px-4 py-16">

    <div class="text-center mb-12">
        <h1 class="font-serif text-4xl md:text-5xl text-antrasit mb-4 font-medium">Bize Ulaşın</h1>
        <p class="text-gri text-lg font-light max-w-2xl mx-auto">
            Önerileriniz, sorularınız veya sadece selam vermek için... Mesajlarınızı okumaktan mutluluk duyarız.
        </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-start">

        <div class="lg:col-span-2 info-card h-full flex flex-col justify-between">
            <div class="pattern-overlay"></div>

            <div class="relative z-10">
                <h3 class="font-serif text-2xl mb-6">İletişim Bilgileri</h3>
                <p class="text-white/80 leading-relaxed mb-8 font-light">
                    Uygulama hakkında geri bildirimde bulunmak veya hataları bildirmek için aşağıdaki kanalları kullanabilirsiniz.
                </p>

                <div class="space-y-6">
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0">
                            <i class="ph ph-envelope-simple text-xl"></i>
                        </div>
                        <div>
                            <p class="text-xs text-white/60 uppercase tracking-wider font-bold mb-1">E-Posta</p>
                            <a href="mailto:iletisim@rehberapp.com" class="text-lg hover:text-altin transition-colors">iletisim@rehberapp.com</a>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0">
                            <i class="ph ph-map-pin text-xl"></i>
                        </div>
                        <div>
                            <p class="text-xs text-white/60 uppercase tracking-wider font-bold mb-1">Konum</p>
                            <p class="text-lg">İstanbul, Türkiye</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="relative z-10 mt-12">
                <p class="text-sm text-white/60 mb-4">Sosyal Medya</p>
                <div class="flex gap-3">
                    <a href="#" class="social-btn"><i class="ph ph-instagram-logo text-xl"></i></a>
                    <a href="#" class="social-btn"><i class="ph ph-twitter-logo text-xl"></i></a>
                    <a href="#" class="social-btn"><i class="ph ph-linkedin-logo text-xl"></i></a>
                </div>
            </div>
        </div>

        <div class="lg:col-span-3 form-card">

            <form method="post" action="/Home/SendContact">

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <div>
                        <label class="block text-sm font-bold text-antrasit mb-2 ml-1">Adınız Soyadınız</label>
                        <input type="text" name="FullName" placeholder="Örn: Ahmet Yılmaz" required
                               class="form-input w-full p-4 rounded-xl outline-none text-antrasit placeholder-gray-400" />
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-antrasit mb-2 ml-1">E-Posta Adresi</label>
                        <input type="email" name="Email" placeholder="ornek@mail.com" required
                               class="form-input w-full p-4 rounded-xl outline-none text-antrasit placeholder-gray-400" />
                    </div>
                </div>

                <div class="mb-6">
                    <label class="block text-sm font-bold text-antrasit mb-2 ml-1">Konu</label>
                    <div class="relative">
                        <select name="Subject" class="form-input w-full p-4 rounded-xl outline-none text-antrasit appearance-none cursor-pointer">
                            <option value="">Seçiniz...</option>
                            <option value="oneri">Öneri / Tavsiye</option>
                            <option value="hata">Hata Bildirimi</option>
                            <option value="iletisim">Genel İletişim</option>
                        </select>
                        <i class="ph ph-caret-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                    </div>
                </div>

                <div class="mb-8">
                    <label class="block text-sm font-bold text-antrasit mb-2 ml-1">Mesajınız</label>
                    <textarea name="Message" rows="5" placeholder="Mesajınızı buraya yazabilirsiniz..." required
                              class="form-input w-full p-4 rounded-xl outline-none text-antrasit placeholder-gray-400 resize-none"></textarea>
                </div>

                <button type="submit" class="w-full py-4 bg-yaprak text-white rounded-xl font-bold text-lg shadow-lg shadow-yaprak/20 hover:bg-yaprak/90 hover:-translate-y-1 transition-all flex items-center justify-center gap-2">
                    <span>Mesajı Gönder</span>
                    <i class="ph ph-paper-plane-tilt"></i>
                </button>

            </form>
        </div>

    </div>
</div>